# Keep generated and media assets out of text diffs.
*.bin binary
*.mp3 binary
*.mp4 binary
*.jpg binary
*.png binary
*.webp binary
*.otf binary
*.ttf binary
*.woff2 binary

# Normalize source files across development environments.
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.swift text eol=lf
